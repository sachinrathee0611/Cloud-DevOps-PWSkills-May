      "isDeleted": false,
      "boundElements": [],
      "updated": 1779613553619,
      "link": null,
      "locked": false,
      "text": "THIS Stage begins when the application is accessible to the users finally!\nThe users actively use the deployed app, generate queries,  transmit issues,\ndemand change etc.\n\nThese all processes are handled by the OPERATION stage!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "THIS Stage begins when the application is accessible to the users finally!\nThe users actively use the deployed app, generate queries,  transmit issues,\ndemand change etc.\n\nThese all processes are handled by the OPERATION stage!",
      "autoResize": true,
      "lineHeight": 1.25
