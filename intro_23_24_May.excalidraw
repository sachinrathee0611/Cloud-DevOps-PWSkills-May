      "seed": 1634344477,
      "version": 431,
      "versionNonce": 139787485,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779613307857,
      "link": null,
      "locked": false,
      "text": "DEPLOY stage is the final stage where a Built package is deployed onto a server so that\nthe final users can access it using the DNS/IP address.\n\nThis stage also ensures that future versions of the application are deployed to the server\nautomatically from the Production environment.\n\nThis automatic deployment reduces development times, lesser latency, faster results, better\ntracking etc.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DEPLOY stage is the final stage where a Built package is deployed onto a server so that\nthe final users can access it using the DNS/IP address.\n\nThis stage also ensures that future versions of the application are deployed to the server\nautomatically from the Production environment.\n\nThis automatic deployment reduces development times, lesser latency, faster results, better\ntracking etc.",
      "autoResize": true,
      "lineHeight": 1.25
    },
