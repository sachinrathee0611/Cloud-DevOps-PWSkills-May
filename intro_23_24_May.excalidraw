      "versionNonce": 2025827987,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779610319283,
      "link": null,
      "locked": false,
      "text": "Also known as 'Development' stage! All the code files are created here, based on the\nplanning phase done earlier!\n\nUtilizing programming concepts and tools like OOPS (Classes/ Objects), data structures and\nalgorithms, Infrastructure as Code (IaC), scripting etc.\n\nThis page also ensures that a code history is kept so as to revert to any point\nat any stage of the programming.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Also known as 'Development' stage! All the code files are created here, based on the\nplanning phase done earlier!\n\nUtilizing programming concepts and tools like OOPS (Classes/ Objects), data structures and\nalgorithms, Infrastructure as Code (IaC), scripting etc.\n\nThis page also ensures that a code history is kept so as to revert to any point\nat any stage of the programming.",
      "autoResize": true,
      "lineHeight": 1.25
    },
