      ],
      "updated": 1779612467157,
      "link": null,
      "locked": false,
      "text": "TEST : This stage tests the built package, and makes sure it is valid and deployable!\n\n            It tests the rules and sets of standards on which an application and its package is built.\n            It also checks if there are any vulnerabilties in your image.\n        One can specify an Integration process to FAIL if it doesn't satisfy the majority of the test cases.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TEST : This stage tests the built package, and makes sure it is valid and deployable!\n\n            It tests the rules and sets of standards on which an application and its package is built.\n            It also checks if there are any vulnerabilties in your image.\n        One can specify an Integration process to FAIL if it doesn't satisfy the majority of the test cases.",
      "autoResize": true,
      "lineHeight": 1.25
    },
