      "boundElements": [],
      "updated": 1779610483422,
      "link": null,
      "locked": false,
      "text": "This stage is used to CONNECT the coded files to the end system for deployment, so as\nit can be accessed by the clients.\n\nThe code in this phase passes through a lot of transformations/processes.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This stage is used to CONNECT the coded files to the end system for deployment, so as\nit can be accessed by the clients.\n\nThe code in this phase passes through a lot of transformations/processes.",
      "autoResize": true,
      "lineHeight": 1.25
    },
