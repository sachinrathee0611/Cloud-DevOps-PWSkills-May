    {
      "id": "tklo4pT2opfpT1AcaEtko",
      "type": "text",
      "x": 277,
      "y": 807.5,
      "width": 900.499267578125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
